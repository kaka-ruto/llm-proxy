# LLM Proxy API Keys
# Copy this to .env and fill in your keys.

# OpenCode Zen / Go — get your key at https://opencode.ai/zen
OPENCODE_API_KEY=

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Direct provider keys (optional — only if you use them)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
