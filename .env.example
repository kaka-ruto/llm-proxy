# LLM Proxy API Keys
# Copy this to .env and fill in your keys.
# The proxy delegates credential resolution to ask-auth, which reads from
# ~/.config/ask-rb/auth.json, ~/.auth.json, or these env vars.

# OpenCode Zen / Go — get your key at https://opencode.ai/zen
OPENCODE_API_KEY=

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Direct provider keys (optional — only if you use them directly)
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
