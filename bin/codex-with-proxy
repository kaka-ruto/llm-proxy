#!/usr/bin/env ruby
# frozen_string_literal: true

# Launch Codex Desktop with llm-proxy.
# Codex routes model requests through the proxy via config.toml (llm-proxy enable).

require "fileutils"

PROXY_DIR = File.expand_path("..", __dir__)
LOGS_DIR = File.join(PROXY_DIR, "logs")
FileUtils.mkdir_p(LOGS_DIR)

CODEX_BIN = "/Applications/Codex.app/Contents/MacOS/Codex"
LLM_PROXY_PORT = 8765

def running?(port)
  system("lsof", "-ti", ":#{port}", out: "/dev/null")
end

def kill_by_port(port)
  pid = `lsof -ti :#{port} 2>/dev/null`.strip
  return unless pid.length > 0
  system("kill", pid) rescue nil
  sleep 0.3
end

def kill_all_codex
  `ps aux 2>/dev/null`.lines.each do |line|
    if line.include?("codex app-server")
      pid = line.split[1].to_i
      next if pid == 0
      Process.kill("TERM", pid) rescue nil
    end
  end
  sleep 1
end

def wait_for_port(port, label, timeout: 10)
  deadline = Time.now + timeout
  loop do
    if running?(port)
      puts "  ✅ #{label} ready on port #{port}"
      return true
    end
    if Time.now > deadline
      puts "  ❌ #{label} failed to start within #{timeout}s"
      return false
    end
    sleep 0.5
  end
end

def start_service(cmd, log_path, port, label)
  log_path = File.expand_path(log_path)
  FileUtils.mkdir_p(File.dirname(log_path))

  pid = spawn(*cmd, out: log_path, err: [:child, :out])
  Process.detach(pid)

  unless wait_for_port(port, label)
    if File.exist?(log_path)
      lines = File.read(log_path).lines.last(20)
      puts "  Last #{lines.size} lines of #{log_path}:"
      lines.each { |l| puts "    #{l.chomp}" }
    end
    exit 1
  end
end

# Kill old processes
puts "→ Cleaning up..."
kill_by_port(LLM_PROXY_PORT)
kill_all_codex
sleep 1

# Start llm-proxy
puts "→ Starting llm-proxy..."
start_service(
  ["bundle", "exec", "ruby", File.join(PROXY_DIR, "bin", "llm-proxy")],
  File.join(LOGS_DIR, "proxy.log"),
  LLM_PROXY_PORT, "llm-proxy"
)

# Launch Codex
puts "→ Launching Codex..."
exec(CODEX_BIN)
